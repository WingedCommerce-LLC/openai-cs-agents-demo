# OpenAI Agents Enterprise Template - Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# ENVIRONMENT SETTINGS
# =============================================================================
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Database URL
DATABASE_URL=postgresql://user:password@localhost:5432/agents_dev

# Database connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=10

# =============================================================================
# OPENAI API CONFIGURATION
# =============================================================================
# Your OpenAI API key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model settings
OPENAI_DEFAULT_MODEL=gpt-4.1
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Secret key for JWT tokens (generate a secure random string)
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# JWT settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Credential encryption key (generate a secure random string)
CREDENTIAL_ENCRYPTION_KEY=your-credential-encryption-key-change-this

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# MCP SERVER CONFIGURATION
# =============================================================================
# MCP server registry URL (optional)
MCP_SERVER_REGISTRY_URL=

# Auto-deploy MCP servers
MCP_AUTO_DEPLOY=true

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Enable telemetry
TELEMETRY_ENABLED=true

# Jaeger endpoint for tracing (optional)
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Hot reload for development
HOT_RELOAD=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable SQL query logging
SQL_ECHO=false

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
# Test database URL
TEST_DATABASE_URL=sqlite:///:memory:

# Test Redis URL
TEST_REDIS_URL=redis://localhost:6379/1

# =============================================================================
# KUBERNETES CONFIGURATION (for production)
# =============================================================================
# Kubernetes namespace
K8S_NAMESPACE=openai-agents

# Service account name
K8S_SERVICE_ACCOUNT=agents-backend-sa

# =============================================================================
# EXTERNAL SERVICES (optional)
# =============================================================================
# Vault configuration (for production credential management)
VAULT_URL=
VAULT_TOKEN=

# Kubernetes secrets (for production)
USE_K8S_SECRETS=false

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=false

# Enable audit logging
ENABLE_AUDIT_LOGGING=true

# Enable rate limiting
ENABLE_RATE_LIMITING=true

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================
# Worker processes for production
WORKER_PROCESSES=4

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# Maximum request size (bytes)
MAX_REQUEST_SIZE=10485760

# =============================================================================
# SECURITY HEADERS
# =============================================================================
# Enable security headers
ENABLE_SECURITY_HEADERS=true

# Content Security Policy
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'
