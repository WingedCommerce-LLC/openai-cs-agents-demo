class TestIntegration:
    """Integration tests."""

    @pytest.mark.asyncio
    async def test_server_tools_list(self):
        """Test that all tools are properly registered."""
        from {{ config.package_name }}.server import list_tools

        tools = await list_tools()

        # Should have {{ endpoints | length }} tools
        assert len(tools) == {{ endpoints | length }}

        # Check tool names
        expected_tools = [
            {% for endpoint in endpoints %}
            "{{ generate_tool_name(endpoint) }}",
            {% endfor %}
        ]

        actual_tools = [tool.name for tool in tools]
        assert set(actual_tools) == set(expected_tools)

        # Check that all tools have proper schemas
        for tool in tools:
            assert tool.name
            assert tool.description
            assert tool.inputSchema
            assert tool.inputSchema["type"] == "object"
            assert "properties" in tool.inputSchema


