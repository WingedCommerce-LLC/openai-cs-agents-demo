class TestServerConfig:
    """Test server configuration."""

    def test_default_config(self):
        """Test default configuration values."""
        config = ServerConfig()
        assert config.base_url == "{{ config.base_url or 'https://api.example.com' }}"
        assert config.timeout == {{ config.timeout }}
        assert config.max_retries == 3

    def test_config_from_env(self):
        """Test configuration loading from environment."""
        with patch.dict(os.environ, {
            "API_BASE_URL": "https://test.example.com",
            "API_TIMEOUT": "60",
            {% if config.auth_type != "none" %}
            "{{ config.auth_header.upper().replace('-', '_') }}_TOKEN": "test_token",
            {% endif %}
            "MAX_RETRIES": "5",
        }):
            config = load_config()
            assert config.base_url == "https://test.example.com"
            assert config.timeout == 60
            {% if config.auth_type != "none" %}
            assert config.auth_token == "test_token"
            {% endif %}
            assert config.max_retries == 5


class TestAPIClient:
    """Test API client functionality."""

    @pytest.fixture
    def config(self):
        """Test configuration."""
        return ServerConfig(
            base_url="https://test.example.com",
            timeout=30,
            {% if config.auth_type != "none" %}
            auth_token="test_token",
            {% endif %}
            max_retries=2,
        )

    @pytest.fixture
    def api_client(self, config):
        """Test API client."""
        return APIClient(config)

    @pytest.mark.asyncio
    async def test_successful_request(self, api_client):
        """Test successful API request."""
        mock_response = MagicMock()
        mock_response.status_code = 200
        mock_response.json.return_value = {"status": "success", "data": "test"}
        mock_response.content = b'{"status": "success", "data": "test"}'
        mock_response.raise_for_status.return_value = None

        with patch.object(api_client.client, 'request', return_value=mock_response) as mock_request:
            result = await api_client.request("GET", "/test")

            assert result == {"status": "success", "data": "test"}
            mock_request.assert_called_once()

    @pytest.mark.asyncio
    async def test_request_with_retry(self, api_client):
        """Test request retry logic."""
        # First call fails, second succeeds
        mock_response_fail = MagicMock()
        mock_response_fail.raise_for_status.side_effect = Exception("Network error")

        mock_response_success = MagicMock()
        mock_response_success.status_code = 200
        mock_response_success.json.return_value = {"status": "success"}
        mock_response_success.content = b'{"status": "success"}'
        mock_response_success.raise_for_status.return_value = None

        with patch.object(api_client.client, 'request', side_effect=[mock_response_fail, mock_response_success]):
            with patch('asyncio.sleep'):  # Mock sleep to speed up test
                result = await api_client.request("GET", "/test")

                assert result == {"status": "success"}

    @pytest.mark.asyncio
    async def test_request_max_retries_exceeded(self, api_client):
        """Test request failure after max retries."""
        mock_response = MagicMock()
        mock_response.raise_for_status.side_effect = Exception("Persistent error")

        with patch.object(api_client.client, 'request', return_value=mock_response):
            with patch('asyncio.sleep'):  # Mock sleep to speed up test
                with pytest.raises(Exception, match="Request failed after"):
                    await api_client.request("GET", "/test")

    @pytest.mark.asyncio
    async def test_client_close(self, api_client):
        """Test client cleanup."""
        with patch.object(api_client.client, 'aclose') as mock_close:
            await api_client.close()
            mock_close.assert_called_once()


